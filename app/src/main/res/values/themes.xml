<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Frei" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">#FF6C3FCF</item>
        <item name="colorSecondary">#FF14B8A6</item>
        <item name="colorSurface">#FFFAFAFC</item>
        <item name="colorOnSurface">#FF1B1830</item>
        <item name="backgroundColor">#FFFAFAFC</item>
        <item name="colorOnBackground">#FF1B1830</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.Frei.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#6C3FCF</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/frei_splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.Frei</item>
    </style>

</resources>